PORT=3000
SHUTDOWN_TIMEOUT_MS=30000
HEALTH_CHECK_ENDPOINT=/health
NODE_ENV=production
LOG_LEVEL=info
OTEL_ENABLED=false
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318/v1/traces
# SERVICE_NAME=is-on-water
# SERVICE_VERSION=v1.0.0
# Optional: enable Redis-backed rate limiting (in-memory by default)
# REDIS_URL=redis://localhost:6379
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100
MAX_BATCH_SIZE=500
TRUST_PROXY=true
